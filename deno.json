{
  "name": "@knox/knox",
  "version": "0.1.0",
  "exports": "./src/mod.ts",
  "bin": "./src/cli/cli.ts",
  "tasks": {
    "dev": "deno run --allow-run --allow-read --allow-write --allow-env --allow-net src/cli/cli.ts",
    "test": "deno test --allow-run --allow-read --allow-write --allow-env --allow-net test/",
    "test:unit": "deno test --allow-run --allow-read --allow-write --allow-env test/ --ignore=test/runtime/docker_runtime_test.ts",
    "test:integration": "deno test --allow-run --allow-read --allow-write --allow-env --allow-net test/runtime/docker_runtime_test.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check src/mod.ts src/cli/cli.ts",
    "compile": "deno compile --allow-run --allow-read --allow-write --allow-env --allow-net --output knox src/cli/cli.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1",
    "@std/fs": "jsr:@std/fs@1",
    "@std/cli": "jsr:@std/cli@1",
    "@std/crypto": "jsr:@std/crypto@1",
    "@std/encoding": "jsr:@std/encoding@1",
    "@std/streams": "jsr:@std/streams@1",
    "@std/yaml": "jsr:@std/yaml@1"
  },
  "unstable": ["raw-imports"],
  "compilerOptions": {
    "strict": true
  },
  "lint": {
    "rules": {
      "exclude": ["no-control-regex"]
    }
  }
}
